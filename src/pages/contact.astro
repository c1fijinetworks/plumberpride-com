---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import GoogleContactForm from '~/components/widgets/GoogleContactForm.astro';
import Features from '~/components/widgets/Features.astro';
import Hero from '~/components/widgets/Hero.astro';

const metadata = {
  title: 'Contact Support | Plumber Pride',
  description: 'Have questions about the lifetime deal or need a multi-truck quote? Contact our team today.',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <HeroText 
    tagline="We're in your corner ⭐⭐⭐⭐⭐"
    title="Let's Talk About Your Business." 
    subtitle="Have questions about the lifetime deal? Need a bulk discount for multiple trucks? We respond faster than a burst pipe."
  />

  <GoogleContactForm />

  <Features
    class="-mt-16"
    columns={3}
    items={[
      { title: 'Multi-Truck Discounts', description: 'Running a fleet? Contact us for custom bulk pricing on 3+ trucks.', icon: 'tabler:truck' },
      { title: 'White-Glove Support', description: 'Need help with your widget installation? Our tech team is here to help.', icon: 'tabler:headset' },
      { title: 'Contractor Partnerships', description: 'Are you a marketing consultant for the trades? Let’s work together.', icon: 'tabler:users' },
    ]}
  />

  <Hero class="-mt-16" image={{ src: '/images/testimonial-7.webp', alt: 'Plumber Pride happy client' }} />
</Layout>
